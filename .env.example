# ══════════════════════════════════════════════════════════════
# MS Schlüsseldienst Wetzlar — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ══════════════════════════════════════════════════════════════

# ─── Formspree Endpoints (Kontaktformulare) ───
# Premium Kontaktformular (Reguläre Anfrage)
# Erstelle ein Formular auf https://formspree.io und kopiere die Form-ID
NEXT_PUBLIC_FORMSPREE_ID="your_premium_form_id"

# Notdienst-Formular (Einsatz-Anfragen)
# Erstelle ein zweites Formular für Notdienst-Einsätze
FORMSPREE_EMERGENCY_ENDPOINT="https://formspree.io/f/your_emergency_form_id"

# ─── Calendly (Sicherheitsberatung Buchung) ───
# Erstelle einen Event-Typ auf https://calendly.com und kopiere die Buchungs-URL
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/your-account/your-event-type"

# ─── Google Maps API Key (für Servicegebiet-Karte) ───
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── Site URL (für kanonische URLs und SEO) ───
# Development: http://localhost:3000
# Production (Vercel): https://wetzlar-schluesseldienst.de
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── App Version ───
NEXT_PUBLIC_APP_VERSION="1.0.0"
