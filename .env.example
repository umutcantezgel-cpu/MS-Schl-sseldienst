# ══════════════════════════════════════════════════════════════
# MS Schlüsseldienst Wetzlar — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ══════════════════════════════════════════════════════════════

# Google Maps API Key (für Servicegebiet-Karte)
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# App Version (wird automatisch vom Build gesetzt)
NEXT_PUBLIC_APP_VERSION="0.1.0"

# Base URL (für Smoke-Tests und kanonische URLs)
# Development: http://localhost:3000
# Production: https://schluesseldienst-wetzlar-24.de
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
